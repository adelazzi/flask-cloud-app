# ─────────────────────────────────────────
# Flask
# ─────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=0
APP_PORT=5000

# ─────────────────────────────────────────
# MySQL
# ─────────────────────────────────────────
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=appuser
MYSQL_PASSWORD=apppassword
MYSQL_DATABASE=appdb

# MySQL root (used only by mysql service)
MYSQL_ROOT_PASSWORD=rootpassword

# ─────────────────────────────────────────
# MongoDB
# ─────────────────────────────────────────
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_USER=appuser
MONGO_PASSWORD=apppassword
MONGO_DATABASE=appdb
